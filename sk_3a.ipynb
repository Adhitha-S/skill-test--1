      ],
      "source": [
        "import numpy as np\n",
        "\n",
        "Z = np.array([10+2j, 5+1j, 8+3j])\n",
        "\n",
        "# Series impedance\n",
        "Z_series = np.sum(Z)\n",
        "\n",
        "# Parallel impedance\n",
        "Z_parallel = 1 / np.sum(1/Z)\n",
        "\n",
        "print(\"Series Impedance:\", Z_series)\n",
        "print(\"Parallel Impedance:\", Z_parallel)"
      ]
    }
  ]
}